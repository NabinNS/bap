# Anything listed here is NOT sent to the Docker build context.
# Smaller context = faster builds + better layer cache hit rates.

# Dependencies — rebuilt inside the image
vendor/
node_modules/

# Local env / secrets — never bake into images
.env
.env.*
!.env.example

# Build artifacts
.next/
public/build/
public/hot/
public/storage/

# Laravel runtime state
storage/logs/*
storage/framework/cache/data/*
storage/framework/sessions/*
storage/framework/views/*
storage/framework/testing/*
bootstrap/cache/*.php

# VCS + editor + OS noise
.git/
.gitignore
.gitattributes
.idea/
.vscode/
.DS_Store
Thumbs.db

# Tests, docs, CI — not needed at runtime
tests/
phpunit.xml
README.md
.github/

# Docker meta — avoid invalidating cache on Dockerfile-only edits
Dockerfile
docker-compose*.yml
.dockerignore
